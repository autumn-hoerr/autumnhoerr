<.flash_group flash={@flash} />
<div class="page">
  <header class="site-header">
    <h1 class="nameheading">{gettext("Autumn Hoerr")}</h1>
  </header>
  <div class="content">
    <.nav nav_items={@nav_items} current_section={@current_section} />
    <main id="main" class={@current_section}>
      {@inner_content}
    </main>
  </div>
  <footer class="site-footer">
    &copy; {Date.utc_today().year} Autumn Hoerr
  </footer>
</div>
